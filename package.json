{
  "name": "SocialiseHub",
  "version": "0.1.0",
  "description": "AI-powered business operations tool for Socialise — event analysis, multi-platform publishing, and social media management",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "events",
    "ai",
    "automation",
    "meetup",
    "social-media"
  ],
  "author": "Socialise",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0",
    "tsx": "^4.7.0"
  }
}
