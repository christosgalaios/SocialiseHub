{
  "name": "SocialiseHub",
  "version": "0.1.0",
  "description": "AI-powered business operations tool for Socialise — event analysis, multi-platform publishing, and social media management",
  "type": "module",
  "main": "dist-electron/main.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && vite build client",
    "build:server": "tsc",
    "build:electron": "tsc -p electron/tsconfig.json && tsc -p electron/tsconfig.preload.json",
    "build:client": "vite build client",
    "build:all": "npm run build:server && npm run build:electron && npm run build:client",
    "build:dist": "npm run build:all && electron-builder --config electron-builder.config.cjs",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev": "node scripts/dev.js",
    "dev:web": "node scripts/dev-web.js",
    "dev:api": "tsx watch src/index.ts",
    "dev:client": "vite client",
    "start": "node dist/index.js",
    "start:electron": "electron .",
    "start:web": "node dist/index.js"
  },
  "keywords": [
    "events",
    "ai",
    "automation",
    "meetup",
    "social-media"
  ],
  "author": "Socialise",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.0.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.3.1",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "express": "^5.2.1",
    "recharts": "^3.8.0"
  }
}
