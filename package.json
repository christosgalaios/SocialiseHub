{
  "name": "SocialiseHub",
  "version": "0.1.0",
  "description": "AI-powered business operations tool for Socialise — event analysis, multi-platform publishing, and social media management",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev": "node scripts/dev.js",
    "dev:api": "tsx watch src/index.ts",
    "dev:client": "vite client",
    "build:client": "vite build client",
    "build:all": "npm run build && npm run build:client",
    "start": "node dist/index.js"
  },
  "keywords": [
    "events",
    "ai",
    "automation",
    "meetup",
    "social-media"
  ],
  "author": "Socialise",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.3.1",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "express": "^5.2.1"
  }
}
