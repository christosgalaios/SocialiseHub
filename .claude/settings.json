{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && npm run lint -- --fix --quiet 2>/dev/null || true",
            "timeout": 15000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | grep -qE '\\.env' && echo 'BLOCKED: Do not edit .env files directly. Credentials must be set in production environment only.' && exit 2 || exit 0"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/rebase-guard.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "skills": {
    "enabled": true,
    "directory": ".claude/skills"
  },
  "agents": {
    "enabled": true,
    "directory": ".claude/agents"
  }
}
